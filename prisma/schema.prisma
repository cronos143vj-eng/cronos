// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String
  price          Float
  compareAt      Float?
  images         String[]
  stock          Int         @default(0)
  category       String      @default("classic")
  specifications Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orders         OrderItem[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  status      OrderStatus @default(PENDING)
  total       Float
  stripeId    String?     @unique
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Event {
  id        String      @id @default(cuid())
  type      EventType
  productId String?
  metadata  Json?
  createdAt DateTime    @default(now())
}

enum EventType {
  PAGE_VIEW
  PRODUCT_VIEW
  CHECKOUT_START
  WHATSAPP_REDIRECT
}

enum OrderStatus {
  PENDING
  WAITING_CONTACT
  PAID
  SHIPPED
  CANCELLED
}
